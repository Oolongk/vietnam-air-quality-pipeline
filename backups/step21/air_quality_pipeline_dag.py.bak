from __future__ import annotations

from datetime import timedelta

import pendulum
from airflow import DAG
from airflow.operators.bash import BashOperator


PROJECT_ROOT = "/opt/airflow/project"

LOCAL_TIMEZONE = pendulum.timezone(
    "Asia/Ho_Chi_Minh"
)


def build_python_command(
    module_name: str,
) -> str:
    return (
        "set -euo pipefail\n"
        f"cd {PROJECT_ROOT}\n"
        f"python -m {module_name}"
    )


default_args = {
    "owner": "air-quality-team",
    "depends_on_past": False,
    "retries": 2,
    "retry_delay": timedelta(
        minutes=3
    ),
}


with DAG(
    dag_id=(
        "vietnam_air_quality_"
        "minio_pipeline"
    ),
    description=(
        "Open-Meteo Air Quality "
        "pipeline using MinIO, "
        "TimescaleDB and Airflow"
    ),
    default_args=default_args,
    start_date=pendulum.datetime(
        2026,
        7,
        14,
        tz=LOCAL_TIMEZONE,
    ),
    schedule="*/30 * * * *",
    catchup=False,
    max_active_runs=1,
    dagrun_timeout=timedelta(
        minutes=25
    ),
    tags=[
        "air-quality",
        "open-meteo",
        "minio",
        "timescaledb",
    ],
) as dag:
    sync_dimensions = BashOperator(
        task_id="sync_dimensions",
        bash_command=(
            "cd /opt/airflow/project "
            "&& python -m "
            "scripts.sync_dimensions_to_timescaledb"
        ),
    )
    
    extract_to_minio = BashOperator(
        task_id="extract_to_minio",
        bash_command=build_python_command(
            "scripts."
            "extract_all_points_to_minio"
        ),
        execution_timeout=timedelta(
            minutes=8
        ),
        append_env=True,
    )

    transform_minio_batch = BashOperator(
        task_id=(
            "transform_minio_batch"
        ),
        bash_command=build_python_command(
            "scripts."
            "transform_latest_minio_batch"
        ),
        execution_timeout=timedelta(
            minutes=6
        ),
        append_env=True,
    )

    run_data_quality = BashOperator(
        task_id="run_data_quality",
        bash_command=build_python_command(
            "scripts."
            "run_latest_minio_data_quality"
        ),
        execution_timeout=timedelta(
            minutes=6
        ),
        append_env=True,
    )

    load_timescaledb = BashOperator(
        task_id="load_timescaledb",
        bash_command=build_python_command(
            "scripts."
            "load_latest_minio_clean_batch"
        ),
        execution_timeout=timedelta(
            minutes=8
        ),
        append_env=True,
    )

    process_aqi_alerts = BashOperator(
        task_id="process_aqi_alerts",
        bash_command=build_python_command(
            "scripts."
            "process_latest_aqi_alerts"
        ),
        execution_timeout=timedelta(
            minutes=6
        ),
        append_env=True,
    )

    sync_pipeline_health = BashOperator(
        task_id="sync_pipeline_health",
        bash_command=build_python_command(
            "scripts."
            "sync_latest_minio_pipeline_health"
        ),
        execution_timeout=timedelta(
            minutes=5
        ),
        append_env=True,
    )

    (
    sync_dimensions
        >> extract_to_minio
        >> transform_minio_batch
        >> run_data_quality
        >> load_timescaledb
        >> process_aqi_alerts
        >> sync_pipeline_health
    )